{
  "name": "eigen-tool-gate",
  "version": "0.1.0",
  "private": true,
  "description": "Verified Tool Gating — verifiable pre-action policy enforcement inside an EigenCompute TEE (Part 4 of the EigenCloud Agent Observability series)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/log && cp src/log/schema.sql dist/log/schema.sql",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js",
    "demo": "node --import tsx src/demo/agent.ts",
    "verify": "node --import tsx src/demo/verifier.ts",
    "seal": "node --import tsx src/gate/seal.ts",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@opentelemetry/api": "^1.9.0",
    "ai": "^5.0.0",
    "canonicalize": "^2.0.0",
    "express": "^4.21.1",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.1",
    "pg": "^8.13.1",
    "uuid": "^11.0.3",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.6",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
