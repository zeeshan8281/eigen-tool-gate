# --- Identity (injected by EigenCompute runtime at deploy time; set manually for local dev) ---
AGENT_ID=research-agent-prod
SESSION_ID=local-dev-session

# --- Policy ---
# Path to the policy YAML sealed into the image. Its SHA-256 is part of the attestation.
POLICY_PATH=policies/demo-policy.yaml

# --- Storage ---
# Leave DATABASE_URL unset to use the in-memory decision log (local dev).
# Inside the TEE this points at the co-located PostgreSQL on the encrypted volume.
# DATABASE_URL=postgresql://gate@127.0.0.1:5432/gate

# Where the TEE-sealed signing key is persisted (encrypted /data volume in the enclave).
DATA_DIR=./data

# --- Real agent + tools ---
# Enables POST /agent/run (a real Claude agent) and the web_search tool.
# ANTHROPIC_API_KEY=sk-ant-...
# TAVILY_API_KEY=tvly-...
AGENT_MODEL=claude-sonnet-4-6
# Where file_read/write/delete operate (mapped from the policy's /workspace).
SANDBOX_ROOT=./data/workspace

# --- HTTP ---
PORT=8080

# --- EigenCompute attestation (injected by the runtime; do not set by hand in prod) ---
# ECLOUD_APP_ID=
# IMAGE_DIGEST=
# ECLOUD_ONCHAIN_TX=
EIGEN_VERIFY_URL=https://verify-sepolia.eigencloud.xyz
